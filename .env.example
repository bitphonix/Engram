# Engram — copy this file to .env and fill in your values
# See SETUP.md for step-by-step instructions

# Neo4j AuraDB (required) — from your downloaded credentials file
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_auradb_password

# Gemini API key (required) — from aistudio.google.com
GEMINI_API_KEY=your_gemini_key_from_aistudio

# Sentry error tracking (optional) — from sentry.io
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Datadog APM (optional) — from datadoghq.com
DD_API_KEY=your_datadog_api_key
DD_SERVICE=engram
DD_SITE=us5.datadoghq.com

APP_ENV=development